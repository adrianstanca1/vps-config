import { useProjects, useInvoices, useTeam, useSafety, useRFIs, useDailyReports } from '../../hooks/useData';
import type { Module } from '../../types';

type AnyRow = Record<string, unknown>;

interface DashboardProps {
  setModule: (m: Module) => void;
}

const MONTH_ABBR = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];

function buildChartData(invoices: AnyRow[]) {
  const now = new Date();
  const months: { month: string; revenue: number; profit: number }[] = [];
  for (let i = 5; i >= 0; i--) {
    const d = new Date(now.getFullYear(), now.getMonth() - i, 1);
    months.push({ month: MONTH_ABBR[d.getMonth()], revenue: 0, profit: 0 });
  }
  invoices.filter(inv => inv.status === 'paid').forEach(inv => {
    const dateStr = String(inv.issueDate ?? inv.issue_date ?? '');
    if (!dateStr) return;
    const d = new Date(dateStr);
    const mIdx = months.findIndex(m => m.month === MONTH_ABBR[d.getMonth()] && d.getFullYear() === new Date().getFullYear());
    if (mIdx !== -1) {
      months[mIdx].revenue += Number(inv.amount ?? 0);
      months[mIdx].profit  += Number(inv.amount ?? 0) * 0.23;
    }
  });
  return months;
}

function fmtM(n: number) {
  if (n >= 1_000_000) return `£${(n / 1_000_000).toFixed(2)}M`;
  if (n >= 1_000)     return `£${(n / 1_000).toFixed(0)}K`;
  return `£${n.toLocaleString()}`;
}

// Stat card with amber top accent line
function StatCard({
  label, value, sub, positive, icon: Icon, delay, onClick,
}: {
  label: string; value: string; sub: string; positive: boolean;
  icon: React.FC<{ className?: string; style?: React.CSSProperties }>;
  delay: number; onClick?: () => void;
}) {
  return (
    <button
      onClick={onClick}
      className="card card-grid card-hover animate-fade-up"
      style={{ animationDelay: `${delay}ms`, padding: '20px', cursor: onClick ? 'pointer' : 'default', textAlign: 'left', width: '100%', border: 'none' }}
    >
      {/* Amber top accent line */}
      <div style={{
        position: 'absolute', top: 0, left: '16px', right: '16px', height: '2px',
        background: positive
          ? 'linear-gradient(90deg, var(--amber-600), var(--amber-400))'
          : 'linear-gradient(90deg, var(--slate-700), transparent)',
        borderRadius: '0 0 4px 4px',
      }} />
      <div style={{ display: 'flex', justifyContent: 'space-between', alignItems: 'flex-start', marginBottom: '16px' }}>
        <span className="text-label-xs">{label}</span>
        <Icon style={{ width: '18px', height: '18px', color: positive ? 'var(--amber-400)' : 'var(--slate-500)' }} />
      </div>
      <div style={{ fontFamily: 'var(--font-mono)', fontSize: '1.6rem', fontWeight: 700, color: 'var(--slate-50)', letterSpacing: '-0.04em', lineHeight: 1, marginBottom: '8px' }}>
        {value}
      </div>
      <div style={{ display: 'flex', alignItems: 'center', gap: '6px' }}>
        {positive
          ? <TrendingUp style={{ width: '12px', height: '12px', color: 'var(--emerald-400)' }} />
          : <TrendingDown style={{ width: '12px', height: '12px', color: 'var(--red-400)' }} />
        }
        <span style={{
          fontFamily: 'var(--font-mono)', fontSize: '10px', fontWeight: 500,
          color: positive ? 'var(--emerald-400)' : 'var(--red-400)',
          letterSpacing: '0.04em',
        }}>
          {sub}
        </span>
      </div>
    </button>
  );
}

